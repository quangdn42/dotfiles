#!/bin/bash
set -euo pipefail

mako_config="$HOME/.config/omarchy/current/theme/mako.ini"

if [[ -f $mako_config ]]; then
  tmp=$(mktemp)
  sed '/^# Dotfiles text scale$/,/^# End dotfiles text scale$/d' "$mako_config" >"$tmp"
  cp "$tmp" "$mako_config"
  rm -f "$tmp"

  cat >>"$mako_config" <<'MAKO_TEXT_SCALE'

# Dotfiles text scale
font=sans-serif 21px
width=630
padding=15,22
max-icon-size=48
# End dotfiles text scale
MAKO_TEXT_SCALE
fi

makoctl reload 2>/dev/null || true
