cursor-invert-fg-bg = true
# no blinking cursor
shell-integration-features = no-cursor
mouse-hide-while-typing = true
macos-option-as-alt = true

font-size = 16
font-family = "IBM Plex Mono"
# for IBM Plex: 2%
# adjust-cell-height = 2%
# adjust-cursor-height = 13%
theme = Kanagawa Wave
macos-titlebar-style = tabs
# background-opacity = 0.95
unfocused-split-opacity = 1
adjust-cursor-thickness = 100%
window-new-tab-position = end
window-save-state = always

# keybinds
keybind = cmd+enter=new_split:down
keybind = cmd+shift+enter=new_split:right
keybind = ctrl+left=resize_split:left,10
keybind = ctrl+down=resize_split:down,10
keybind = ctrl+up=resize_split:up,10
keybind = ctrl+right=resize_split:right,10
keybind = cmd+r=reload_config

keybind = alt+right=unbind
keybind = alt+left=unbind

keybind = cmd+f=write_scrollback_file:open

# keybind = cmd+k=text:\x0C
