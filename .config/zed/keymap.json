[
  {
    // VimControl: Indicates that vim keybindings should work.
    // Currently an alias for vim_mode == normal || vim_mode == visual || vim_mode == operator,
    // but the definition may change over time
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",

      // Vimsneak
      "backspace": "vim::PushSneak",
      "shift-backspace": "vim::PushSneakBackward",

      // Substitute
      "g p": "vim::PushReplaceWithRegister"
    }
  },
  // Normal & Visual
  {
    "context": "vim_mode == normal || vim_mode == visual && !menu",
    "bindings": {
      // Editing
      "alt-down": "editor::MoveLineDown",
      "alt-up": "editor::MoveLineUp",
      ">": "editor::Indent",
      "<": "editor::Outdent",
      "g h": "vim::FirstNonWhitespace",
      "g l": "vim::EndOfLine",
      "alt-o": "editor::SelectLargerSyntaxNode",
      "alt-i": "editor::SelectSmallerSyntaxNode",

      // Subword
      // "w": ["vim::NextSubwordStart", { "ignore_punctuation": false }],
      // "e": ["vim::NextSubwordEnd", { "ignore_punctuation": false }],
      // "b": "vim::PreviousSubwordStart",
      // "g e": "vim::PreviousSubwordEnd",

      // LSP Actions
      "space c a": "editor::ToggleCodeActions",
      "g .": null,
      "space c r": "editor::Rename",
      "g r": "editor::FindAllReferences",
      "space c h": "editor::SwitchSourceHeader"
    }
  },
  // Normal
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      // Editing
      "shift-y": ["workspace::SendKeystrokes", "y $"],
      "U": "editor::Redo",
      "space c f": "editor::Format",

      // Navigation
      "space b": "tab_switcher::Toggle",
      "space e": "pane::RevealInProjectPanel",
      "space f": "file_finder::Toggle",
      "space s s": "outline::Toggle",
      "space s S": "project_symbols::Toggle",
      "H": "pane::ActivatePreviousItem",
      "L": "pane::ActivateNextItem",
      "space \\": "pane::SplitRight",
      "space -": "pane::SplitDown",
      "space `": "pane::AlternateFile",

      // Git operations
      "space g D": "git::Diff",
      "space g R": "git::RestoreFile",
      "space g S": "git::StageFile",
      "space g U": "git::UnstageFile",
      "space g a": "git::Add",
      "space g d": "editor::ToggleSelectedDiffHunks",
      "space g r": "git::Restore",
      "space g s": "git::StageAndNext",
      "space g t": "git::ToggleStaged",
      "space g u": "git::UnstageAndNext",

      // Debug operations
      "space d l": "debugger::Rerun",

      // treesitter related
      "alt-o": "vim::SelectLargerSyntaxNode",
      "alt-i": "vim::SelectSmallerSyntaxNode"
    }
  },
  // Visual
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": ["vim::PushAddSurrounds", {}],
      "space c f": "editor::FormatSelections"
    }
  },
  // Insert
  {
    "context": "vim_mode == insert",
    "bindings": {
      "alt-down": "editor::MoveLineDown",
      "alt-up": "editor::MoveLineUp"
    }
  },
  // Operator
  {
    "context": "vim_mode == operator",
    "bindings": {
      "v": "vim::Subword"
    }
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      "b": "vim::MiniBrackets",
      // "g": "vim::EntireFile",
      "shift-v": ["vim::Subword", { "ignore_punctuation": true }]
    }
  },
  // Project Panel
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "d": "project_panel::Delete",
      // "enter": ["workspace::SendKeystrokes", "o space e"],
      "g Y": "workspace::CopyRelativePath",
      "g y": "workspace::CopyPath",
      "p": "project_panel::Paste",
      "q": "workspace::ToggleLeftDock",
      "r": "project_panel::Rename",
      "shift-a": "project_panel::NewDirectory",
      "x": "project_panel::Cut",
      "y": "project_panel::Copy"
    }
  },
  // Git Panel
  {
    "context": "GitPanel && ChangesList",
    "bindings": {
      "a": "git::StageAll",
      "b": "git::Branch",
      "c": "git::Commit",
      "d": "git::RestoreFile",
      "f": "git::Fetch",
      "p": "git::Pull",
      "P": "git::Push",
      "q": "workspace::ToggleLeftDock",
      "backspace": null,
      "escape": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "GitPanel > Editor",
    "bindings": {
      "alt-y": "git::GenerateCommitMessage",
      "escape": "git_panel::FocusChanges"
    }
  },
  {
    "context": "GitCommit > Editor",
    "bindings": {
      "alt-y": "git::GenerateCommitMessage"
    }
  },
  // Terminal
  {
    "context": "Terminal",
    "bindings": {
      "cmd-enter": "workspace::NewTerminal",
      "ctrl-m": "workspace::ToggleZoom",
      "cmd-x": "terminal::ToggleViMode",
      "cmd-k": ["terminal::SendKeystroke", "ctrl-l"],
      "cmd-t": "workspace::NewTerminal",
      "cmd-1": "workspace::ToggleBottomDock",
      "cmd-2": "workspace::CloseActiveDock",
      "ctrl-`": "workspace::ToggleBottomDock",
      "alt-left": null,
      "alt-right": null
    }
  },
  // Editor wide
  {
    // NOTE: This is truly global, no context!
    "bindings": {
      "cmd-o": "projects::OpenRecent",
      "alt-cmd-o": "workspace::Open",
      "cmd-1": "workspace::CloseAllDocks",
      "cmd-2": "terminal_panel::ToggleFocus",

      "f5": "debugger::Start",
      "shift-f5": "debugger::Stop",
      "ctrl-f5": "debugger::Restart",
      "f3": "debugger::StepOver",
      "f2": "debugger::StepInto",
      "f1": "debugger::StepOut"
    }
  },
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      // Put key bindings here (in addition to the context above) if you want them to
      // work when no editor exists.
      "space b": "tab_switcher::Toggle",
      "space e": "pane::RevealInProjectPanel",
      "space f": "file_finder::Toggle"
    }
  },
  {
    "context": "Workspace && debugger_running",
    "use_key_equivalents": true,
    "bindings": {
      "space d e": "debugger::EvaluateSelectedText"
    }
  },

  // Pane navigation
  {
    "context": "Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
      // ... or other keybindings
    }
  },

  // Code Completion (Language Server)
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-m": "editor::ConfirmCompletion",
      "ctrl-y": "editor::ConfirmCompletion",
      "enter": "editor::NewlineBelow"
    }
  },
  // Edit Prediction (Zed Completion)
  {
    "context": "Editor && mode == full && edit_prediction",
    "use_key_equivalents": true,
    "bindings": {
      "alt-y": "editor::NextEditPrediction",
      "alt-shift-y": "editor::PreviousEditPrediction",
      "alt-p": "editor::AcceptPartialEditPrediction"
    }
  },
  {
    "context": "Editor && !edit_prediction",
    "use_key_equivalents": true,
    "bindings": {
      "alt-y": "editor::ShowEditPrediction",
      "tab": "editor::Tab"
    }
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "alt-y": "editor::AcceptEditPrediction",
      "tab": null
    }
  },
  {
    "context": "Editor && edit_prediction_conflict",
    "use_key_equivalents": true,
    "bindings": {
      "alt-y": "editor::AcceptEditPrediction",
      "tab": null
    }
  },
  // Bind `tab` back to its original behavior.
  {
    "context": "Editor",
    "bindings": {
      "tab": "editor::Tab"
    }
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "tab": "editor::ComposeCompletion"
    }
  },
  {
    "context": "(VimControl && !menu) || vim_mode == replace || vim_mode == waiting",
    "bindings": {
      "tab": "vim::Tab"
    }
  },
  {
    "context": "vim_mode == literal",
    "bindings": {
      "tab": ["vim::Literal", ["tab", "\u0009"]]
    }
  },
  // END bind `tab` back

  // Tab Switcher
  {
    "context": "TabSwitcher",
    "bindings": {
      "x": "tab_switcher::CloseSelectedItem"
    }
  },
  // FileFinder split
  {
    "context": "FileFinder || (FileFinder > Picker > Editor) || (FileFinder > Picker > menu)",
    "use_key_equivalents": true,
    "bindings": {
      "cmd-shift-p": "file_finder::SelectPrevious",
      "ctrl-s": "pane::SplitDown",
      "ctrl-v": "pane::SplitRight"
    }
  }
]
